{
  "name": "prompt-is-all-you-need",
  "version": "0.1.0",
  "description": "Local-first desktop prompt launcher and miner for Codex and Claude Code.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "electron-vite": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sql.js": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/sql.js": "latest",
    "electron": "latest",
    "typescript": "latest",
    "vite": "^7.3.6",
    "vitest": "latest"
  }
}
